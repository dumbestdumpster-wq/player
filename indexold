<!DOCTYPE html>
<html>
<head>
  <title>player</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    body {
      background: #0d0d0d;
      color: #e6e6e6;
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 20px;
    }

    .container {
      max-width: 750px;
      margin: auto;
      background: #111;
      padding: 20px;
      border-radius: 12px;
      border: 1px solid #222;
    }

    input, select {
      width: 100%;
      padding: 12px;
      margin-top: 8px;
      margin-bottom: 15px;
      background: #1a1a1a;
      color: #eee;
      border: 1px solid #333;
      border-radius: 6px;
      font-size: 16px;
    }

    button {
      padding: 12px 18px;
      font-size: 16px;
      border: none;
      border-radius: 6px;
      background: #333;
      color: white;
      cursor: pointer;
      transition: 0.2s;
    }

    button:hover {
      background: #444;
    }

    .result-item {
      cursor: pointer;
      margin-bottom: 15px;
      padding: 12px;
      border: 1px solid #333;
      border-radius: 8px;
      background: #1a1a1a;
      transition: 0.2s;
    }

    .result-item:hover {
      background: #222;
    }

    img {
      border-radius: 8px;
      margin-top: 10px;
      border: 1px solid #333;
    }

    iframe {
      width: 100%;
      height: 600px;
      border: 1px solid #333;
      border-radius: 8px;
      background: black;
    }
  </style>
</head>

<body>
<div class="container">
  <h2>🎬 Ultimate TMDb + VidKing Player</h2>

  <input id="searchInput" type="text" placeholder="Search movies or TV shows...">

  <button onclick="searchTMDB()">Search</button>

  <div id="searchResults" style="margin-top:20px;"></div>

  <div id="selectorArea" style="margin-top:20px;display:none;">
    <h3 id="selectedTitle"></h3>

    <label>Season:</label>
    <select id="seasonSelect" onchange="loadEpisodes()"></select>

    <label>Episode:</label>
    <select id="episodeSelect" onchange="loadPlayer()"></select>
  </div>

  <div id="playerContainer" style="margin-top:20px;"></div>
</div>

<script>
const API_KEY = "3ca5f3df3ee394337393273aa440c425";
let currentID = null;
let currentType = null;

function searchTMDB() {
  const query = document.getElementById("searchInput").value;
  if (!query) return alert("Type something first!");

  const urlMovie = `https://api.themoviedb.org/3/search/movie?api_key=${API_KEY}&query=${encodeURIComponent(query)}`;
  const urlTV = `https://api.themoviedb.org/3/search/tv?api_key=${API_KEY}&query=${encodeURIComponent(query)}`;

  Promise.all([fetch(urlMovie), fetch(urlTV)])
    .then(responses => Promise.all(responses.map(r => r.json())))
    .then(([movies, tv]) => displayResults(movies.results, tv.results));
}

function displayResults(movies, tv) {
  const container = document.getElementById("searchResults");
  container.innerHTML = "<h3>Results:</h3>";

  const all = [
    ...movies.map(m => ({...m, media_type: "movie"})),
    ...tv.map(t => ({...t, media_type: "tv"}))
  ];

  if (all.length === 0) {
    container.innerHTML = "<p>No results found.</p>";
    return;
  }

  all.forEach(item => {
    const title = item.media_type === "movie" ? item.title : item.name;
    const poster = item.poster_path ? `https://image.tmdb.org/t/p/w200${item.poster_path}` : "";

    container.innerHTML += `
      <div class="result-item" onclick="selectItem(${item.id}, '${item.media_type}', '${title.replace(/'/g, "\\'")}')">
        <strong>${title}</strong> (${item.media_type.toUpperCase()})<br>
        ${poster ? `<img src="${poster}">` : ""}
      </div>
    `;
  });
}

function selectItem(id, type, title) {
  currentID = id;
  currentType = type;

  document.getElementById("selectedTitle").innerText = title;
  document.getElementById("selectorArea").style.display = "block";

  if (type === "movie") {
    loadMoviePlayer();
  } else {
    loadSeasons();
  }
}

function loadMoviePlayer() {
  const url = `https://www.vidking.net/embed/movie/${currentID}?autoPlay=true`;

  document.getElementById("playerContainer").innerHTML =
    `<iframe src="${url}"
      allow="fullscreen"
      allowfullscreen
      webkitallowfullscreen
      mozallowfullscreen></iframe>`;
}

function loadSeasons() {
  const url = `https://api.themoviedb.org/3/tv/${currentID}?api_key=${API_KEY}`;

  fetch(url)
    .then(res => res.json())
    .then(data => {
      const seasonSelect = document.getElementById("seasonSelect");
      seasonSelect.innerHTML = "";

      data.seasons.forEach(season => {
        if (season.season_number > 0) {
          seasonSelect.innerHTML += `<option value="${season.season_number}">Season ${season.season_number}</option>`;
        }
      });

      loadEpisodes();
    });
}

function loadEpisodes() {
  const season = document.getElementById("seasonSelect").value;
  const url = `https://api.themoviedb.org/3/tv/${currentID}/season/${season}?api_key=${API_KEY}`;

  fetch(url)
    .then(res => res.json())
    .then(data => {
      const episodeSelect = document.getElementById("episodeSelect");
      episodeSelect.innerHTML = "";

      data.episodes.forEach(ep => {
        episodeSelect.innerHTML += `<option value="${ep.episode_number}">Episode ${ep.episode_number}</option>`;
      });

      loadPlayer();
    });
}

function loadPlayer() {
  const season = document.getElementById("seasonSelect").value;
  const episode = document.getElementById("episodeSelect").value;

  const url = `https://www.vidking.net/embed/tv/${currentID}/${season}/${episode}?autoPlay=true&nextEpisode=true&episodeSelector=true`;

  document.getElementById("playerContainer").innerHTML =
    `<iframe src="${url}"
      allow="fullscreen"
      allowfullscreen
      webkitallowfullscreen
      mozallowfullscreen></iframe>`;
}
</script>

</body>
</html>
